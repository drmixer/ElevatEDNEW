    "seed:launch-all": "tsx scripts/seed_launch_lessons_all.ts --apply",
    "seed:launch-all:guarded": "npm run seed:launch-all && npm run eval:question-bank-gate",
    "seed:practice-questions": "tsx scripts/seed_practice_questions.ts --apply",
    "seed:practice-questions:guarded": "npm run seed:practice-questions && npm run eval:question-bank-gate",
    "cleanup:duplicate-public-lessons": "tsx scripts/resolve_duplicate_public_lessons.ts --apply",
    "seed:module-standards-auto": "tsx scripts/seed_module_standards_auto.ts --apply",
    "seed:lesson-metadata": "tsx scripts/seed_lesson_metadata.ts --apply",
    "seed:lesson-exit-tickets": "tsx scripts/seed_lesson_exit_tickets.ts --apply",
    "seed:fallback-assets": "tsx scripts/seed_fallback_assets.ts --apply",
    "seed:placement-assessment": "tsx scripts/seed_placement_assessment.ts --apply",
    "audit:placement": "tsx scripts/audit_placement_readiness.ts",
    "audit:cat-coverage": "tsx scripts/audit_cat_content_coverage.ts",
    "audit:licenses": "tsx scripts/audit_licenses.ts",
    "audit:completeness": "tsx scripts/audit_completeness.ts",
    "audit:question-bank-quality": "tsx scripts/audit_question_bank_quality.ts",
    "eval:question-bank-gate": "tsx scripts/audit_question_bank_quality.ts --max-flagged 0 --max-blocked 0 --max-generic 0 --max-flagged-rate 0",
    "audit:coverage-rollup": "tsx scripts/coverage_quick_rollup.ts --grades 3,4,5,6,7,8",
    "build:math-prereq-map": "tsx scripts/build_math_3_8_prerequisite_map.ts --write",
    "audit:math-prereq-map": "tsx scripts/build_math_3_8_prerequisite_map.ts --audit",
    "build:math-adaptive-variants": "tsx scripts/build_math_adaptive_variants.ts --write",
    "audit:math-adaptive-variants": "tsx scripts/build_math_adaptive_variants.ts",
    "test:math-adaptive-policy": "vitest --run server/__tests__/mathAdaptivePolicy.test.ts",
    "test:homeschool-daily-plan": "vitest --run server/__tests__/homeschoolDailyPlan.test.ts",
    "test:homeschool-plans": "vitest --run server/__tests__/homeschoolPlans.test.ts",
    "test:homeschool-api": "vitest --run server/__tests__/api.integration.test.ts",
    "audit:coverage-gaps": "tsx scripts/report_coverage_gaps.ts",
    "audit:traffic-report": "tsx scripts/report_high_traffic_modules.ts",
    "audit:practice": "tsx scripts/audit_practice_coverage.ts",
    "eval:release-gates": "tsx scripts/evaluate_release_gates.ts",
    "eval:release-gates:live": "tsx scripts/evaluate_release_gates.ts --telemetry-mode live",
    "eval:release-gates:synthetic": "tsx scripts/evaluate_release_gates.ts --telemetry-mode synthetic",
    "eval:release-gates:full": "tsx scripts/evaluate_release_gates_full.ts",
    "seed:synthetic-success-telemetry": "tsx scripts/seed_synthetic_success_telemetry.ts --apply",
    "fix:generic-question-bank": "tsx scripts/remediate_generic_question_bank.ts",
    "fix:question-bank-top-batch": "tsx scripts/remediate_top_question_bank_batch.ts",
    "audit:coaching-feedback": "tsx tools/report_coaching_feedback.ts",
    "seed:lessons": "tsx scripts/seed_lessons.ts --apply",
    "seed:module-assessments": "tsx scripts/seed_module_assessments.ts --all --apply",
    "seed:module-assessments:guarded": "npm run seed:module-assessments && npm run eval:question-bank-gate",
    "import:worker": "tsx server/importWorker.ts",
    "api:dev": "tsx server/index.ts"
  },
  "dependencies": {
    "@sentry/node": "^8.29.0",
    "@sentry/react": "^8.29.0",
    "@supabase/supabase-js": "^2.74.0",
    "@tanstack/react-query": "^5.90.2",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.8.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^16.12.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^27.0.0",
    "pg": "^8.16.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vitest": "^3.2.4"
  }
}
