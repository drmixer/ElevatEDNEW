{
  "name": "elevated-education-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:files": "eslint",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:db:adaptive": "RUN_DB_INTEGRATION_TESTS=true vitest --run server/__tests__/learningPaths.db.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:auth-reload": "playwright test tests/e2e/auth-reload-timeout.spec.ts",
    "import:oer": "tsx tools/importers/oer/index.ts",
    "db:migrate": "supabase migration up",
    "seed:skeleton": "tsx scripts/import_skeleton.ts --apply",
    "import:openstax": "tsx scripts/import_openstax.ts --apply",
    "import:openstax:guarded": "npm run import:openstax && npm run eval:question-bank-gate",
    "import:gutenberg": "tsx scripts/import_gutenberg.ts --apply",
    "import:provider-dataset": "tsx scripts/import_provider_dataset.ts --apply",
    "import:provider-dataset:guarded": "npm run import:provider-dataset && npm run eval:question-bank-gate",
    "import:authored-practice": "tsx scripts/import_authored_practice.ts --apply",
    "import:authored-practice:guarded": "npm run import:authored-practice && npm run eval:question-bank-gate",
    "import:external-resources": "tsx scripts/import_external_resources.ts --apply",
    "import:curated-assets": "tsx scripts/import_curated_assets.ts --apply",
    "import:federal": "tsx scripts/import_federal_pd.ts --apply",
    "import:provider": "tsx tools/importers/providers/index.ts",
    "import:standards": "tsx scripts/import_standards.ts --apply",
    "import:module-standards": "tsx scripts/import_module_standards.ts --apply",
